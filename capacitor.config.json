{
  "appId": "in.mxprime.calcmind.app",
  "appName": "CalcMind",
  "webDir": "dist",
  "plugins": {
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com", "phone", "password"]
    },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchFadeOutDuration": 300,
      "launchAutoHide": true,
      "backgroundColor": "#1A1B22",
      "showSpinner": false
    }
  }
}
